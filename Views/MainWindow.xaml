<Window x:Class="PersonalLibraryManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PersonalLibraryManager.ViewModels"
        mc:Ignorable="d"
        Title="Personal Library Manager" Height="450" Width="800">
    <Window.DataContext>
        <local:MainViewModel/>
    </Window.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            <MenuItem Header="File">
                <MenuItem Header="Exit" Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="Books">
                <MenuItem Header="Add New Book" Command="{Binding AddBookCommand}"/>
                <MenuItem Header="Edit Book" Command="{Binding EditBookCommand}"/>
                <MenuItem Header="Delete Book" Command="{Binding DeleteBookCommand}"/>
            </MenuItem>
            <MenuItem Header="Help">
                <MenuItem Header="About" Command="{Binding AboutCommand}"/>
            </MenuItem>
        </Menu>

        <DataGrid Grid.Row="1" ItemsSource="{Binding Books}" SelectedItem="{Binding SelectedBook}" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="200"/>
                <DataGridTextColumn Header="Author" Binding="{Binding Author}" Width="150"/>
                <DataGridTextColumn Header="ISBN" Binding="{Binding ISBN}" Width="100"/>
                <DataGridTextColumn Header="Genre" Binding="{Binding Genre}" Width="100"/>
                <DataGridTextColumn Header="Year" Binding="{Binding PublicationYear}" Width="80"/>
                <DataGridCheckBoxColumn Header="Read" Binding="{Binding IsRead}" Width="60"/>
                <DataGridTextColumn Header="Rating" Binding="{Binding Rating}" Width="60"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>